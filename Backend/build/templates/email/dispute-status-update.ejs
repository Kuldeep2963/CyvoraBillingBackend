<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; border: 1px solid #ddd; border-radius: 5px; }
        .header { background-color: #007bff; color: white; padding: 10px; text-align: center; border-radius: 5px 5px 0 0; }
        .content { padding: 20px; }
        .footer { font-size: 12px; color: #777; margin-top: 20px; border-top: 1px solid #ddd; padding-top: 10px; }
        .dispute-details { background-color: #f9f9f9; padding: 15px; border-radius: 5px; margin: 20px 0; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Dispute Status Updated</h1>
        </div>
        <div class="content">
                <p><strong> Hi,<%= customer.accountName %></strong></p>
            <p>The status of the dispute for invoice <%= dispute.invoiceNumber %> has been changed to <strong><%= status.replace('_', ' ').toUpperCase() %></strong>.</p>
            <div class="dispute-details">
                <p><strong>Customer:</strong> <%= customer.accountName %></p>
                <p><strong>Customer Code:</strong> <%= customer.customerCode %></p>
                <p><strong>Invoice Number:</strong> <%= dispute.invoiceNumber %></p>
                <p><strong>Dispute Amount:</strong> <%= customer.currency %> <%= dispute.disputeAmount %></p>
                <p><strong>Previous Status:</strong> <%= dispute.status %></p>
                <p><strong>New Status:</strong> <%= status %></p>
                <p><strong>Resolved At:</strong> <%= dispute.resolvedAt ? new Date(dispute.resolvedAt).toLocaleString() : 'N/A' %></p>
            </div>
            <div>
                <p><strong>Best regards,</strong></p>
                <p><strong>CDR Billing System Team</strong></p>
                <% if (logoSrc) { %>
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin-top: 10px;">
                    <tr>
                        <td style="text-align: left;">
                            <img src="<%= logoSrc %>" alt="Cyvora" style="max-width: 120px; width: 120px; height: auto; display: block;" />
                        </td>
                    </tr>
                </table>
                <% } %>
            </div>
        </div>
        <div class="footer">
            <p>&copy; <%= new Date().getFullYear() %> CDR Billing System. All rights reserved.</p>
        </div>
    </div>
</body>
</html>