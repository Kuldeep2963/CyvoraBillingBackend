<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; border: 1px solid #ddd; border-radius: 5px; }
        .header { background-color: #28a745; color: white; padding: 10px; text-align: center; border-radius: 5px 5px 0 0; }
        .content { padding: 20px; }
        .footer { font-size: 12px; color: #777; margin-top: 20px; border-top: 1px solid #ddd; padding-top: 10px; }
        .payment-details { background-color: #f9f9f9; padding: 15px; border-radius: 5px; margin: 20px 0; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Payment Received</h1>
        </div>
        <div class="content">
            <p>Dear <%= customer.accountName %>,</p>
            <p>Thank you for your payment. We have received it successfully.</p>
            
            <div class="payment-details">
                <p><strong>Payment Number:</strong> <%= payment.paymentNumber %></p>
                <p><strong>Amount Paid:</strong> <%= payment.amount %> <%= payment.currency || 'USD' %></p>
                <p><strong>Date:</strong> <%= new Date(parseInt(payment.paymentDate)).toLocaleDateString() %></p>
                <p><strong>Payment Method:</strong> <%= payment.paymentMethod %></p>
            </div>

            <h3>Payment Allocations</h3>
            <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                <thead>
                    <tr style="background-color: #f2f2f2; text-align: left;">
                        <th style="padding: 10px; border: 1px solid #ddd;">Invoice Number</th>
                        <th style="padding: 10px; border: 1px solid #ddd;">Allocated Amount</th>
                        <th style="padding: 10px; border: 1px solid #ddd;">Remaining Balance</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (payment.allocations && payment.allocations.length > 0) { %>
                        <% payment.allocations.forEach(function(allocation) { %>
                            <tr>
                                <td style="padding: 10px; border: 1px solid #ddd;"><%= allocation.invoice.invoiceNumber %></td>
                                <td style="padding: 10px; border: 1px solid #ddd;"><%= allocation.allocatedAmount %> <%= allocation.invoice.currency || 'USD' %></td>
                                <td style="padding: 10px; border: 1px solid #ddd;"><%= allocation.invoice.balanceAmount %> <%= allocation.invoice.currency || 'USD' %></td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td style="padding: 10px; border: 1px solid #ddd;"><%= invoice.invoiceNumber %></td>
                            <td style="padding: 10px; border: 1px solid #ddd;"><%= payment.amount %> <%= invoice.currency || 'USD' %></td>
                            <td style="padding: 10px; border: 1px solid #ddd;"><%= invoice.balanceAmount %> <%= invoice.currency || 'USD' %></td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
            
            <p>If you have any questions, please contact our support team.</p>
            <p>Best regards,<br>
            <strong>CDR Billing System Team</strong></p>
            <% if (logoSrc) { %>
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin-top: 10px;">
                <tr>
                    <td style="text-align: left;">
                        <img src="<%= logoSrc %>" alt="Cyvora" style="max-width: 120px; width: 120px; height: auto; display: block;" />
                    </td>
                </tr>
            </table>
            <% } %>
        </div>
        <div class="footer">
            <p>&copy; <%= new Date().getFullYear() %> CDR Billing System. All rights reserved.</p>
        </div>
    </div>
</body>
</html>
