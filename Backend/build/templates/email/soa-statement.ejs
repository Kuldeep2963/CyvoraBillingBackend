<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
        .container { max-width: 800px; margin: 0 auto; padding: 20px; border: 1px solid #ddd; border-radius: 5px; }
        .header { background-color: #007bff; color: white; padding: 10px; text-align: center; border-radius: 5px 5px 0 0; }
        .content { padding: 20px; }
        .footer { font-size: 12px; color: #777; margin-top: 20px; border-top: 1px solid #ddd; padding-top: 10px; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        th, td { padding: 8px; border: 1px solid #ddd; }
        th { background-color: #f2f2f2; text-align: left; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Statement of Account</h1>
        </div>
        <div class="content">
            <p>Dear <%= account.accountName %>,</p>
            <p>Here is your statement for the period <strong><%= startDate %></strong> to <strong><%= endDate %></strong>.</p>

            <h3>Customer Invoices</h3>
            <% if (soaData.customerInvoices.length) { %>
            <table>
                <thead>
                    <tr><th>Date</th><th>Invoice #</th><th>Amount</th></tr>
                </thead>
                <tbody>
                <% soaData.customerInvoices.forEach(inv => { %>
                    <tr>
                        <td><%= new Date(parseInt(inv.invoiceDate)).toLocaleDateString() %></td>
                        <td><%= inv.invoiceNumber %></td>
                        <td><%= inv.totalAmount %> <%= inv.currency || 'USD' %></td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
            <% } else { %><p>No customer invoices during this period.</p><% } %>

            <h3>Customer Payments</h3>
            <% if (soaData.customerPayments.length) { %>
            <table>
                <thead>
                    <tr><th>Date</th><th>Payment #</th><th>Amount</th></tr>
                </thead>
                <tbody>
                <% soaData.customerPayments.forEach(pay => { %>
                    <tr>
                        <td><%= new Date(parseInt(pay.paymentDate)).toLocaleDateString() %></td>
                        <td><%= pay.paymentNumber %></td>
                        <td><%= pay.amount %> <%= pay.currency || 'USD' %></td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
            <% } else { %><p>No customer payments during this period.</p><% } %>

            <h3>Vendor Invoices</h3>
            <% if (soaData.vendorInvoices.length) { %>
            <table>
                <thead>
                    <tr><th>Date</th><th>Invoice #</th><th>Amount</th></tr>
                </thead>
                <tbody>
                <% soaData.vendorInvoices.forEach(inv => { %>
                    <tr>
                        <td><%= new Date(parseInt(inv.invoiceDate)).toLocaleDateString() %></td>
                        <td><%= inv.invoiceNumber %></td>
                        <td><%= inv.totalAmount %> <%= inv.currency || 'USD' %></td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
            <% } else { %><p>No vendor invoices during this period.</p><% } %>

            <h3>Vendor Payments</h3>
            <% if (soaData.vendorPayments.length) { %>
            <table>
                <thead>
                    <tr><th>Date</th><th>Payment #</th><th>Amount</th></tr>
                </thead>
                <tbody>
                <% soaData.vendorPayments.forEach(pay => { %>
                    <tr>
                        <td><%= new Date(parseInt(pay.paymentDate)).toLocaleDateString() %></td>
                        <td><%= pay.paymentNumber %></td>
                        <td><%= pay.amount %> <%= pay.currency || 'USD' %></td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
            <% } else { %><p>No vendor payments during this period.</p><% } %>

            <% if (soaData.disputes && soaData.disputes.length) { %>
            <h3>Open Disputes</h3>
            <ul>
                <% soaData.disputes.forEach(d => { %>
                    <li><%= d.invoiceNumber %> - <%= d.status %> <% if (d.amount) { %>(<%= d.amount %>)<% } %></li>
                <% }); %>
            </ul>
            <% } %>

            <p>Thank you for your continued business.</p>
            <p>Best regards,<br>
            <strong>CDR Billing System Team</strong></p>
            <% if (logoSrc) { %>
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin-top: 10px;">
                <tr>
                    <td style="text-align: left;">
                        <img src="<%= logoSrc %>" alt="Cyvora" style="max-width: 120px; width: 120px; height: auto; display: block;" />
                    </td>
                </tr>
            </table>
            <% } %>
        </div>
        <div class="footer">
            <p>&copy; <%= new Date().getFullYear() %> CDR Billing System. All rights reserved.</p>
        </div>
    </div>
</body>
</html>