<!DOCTYPE html>
<html>
<head>
    <style>
        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif; 
            font-size: 14px; 
            line-height: 1.6; 
            color: #333; 
            margin: 0; 
            padding: 20px; 
            background-color: #ffffff;
        }
        .container { 
            max-width: 800px; 
            margin: 0 auto; 
        }
        .header { 
            font-size: 16px; 
            font-weight: bold; 
            padding-bottom: 15px; 
            border-bottom: 1px solid #eaeaea; 
            margin-bottom: 20px; 
        }
        .content p { 
            margin: 6px 0; 
        }
        .section-title {
            font-size: 14px;
            font-weight: bold;
            margin-top: 35px;
            margin-bottom: 10px;
            color: #111;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 10px;
        }
        th {
            text-align: left;
            padding: 10px 8px;
            border-bottom: 2px solid #eaeaea;
            color: #555;
            font-weight: bold;
        }
        td {
            padding: 10px 8px;
            border-bottom: 1px solid #eaeaea;
        }
        .empty-state {
            color: #777;
            font-style: italic;
            padding: 10px 8px;
        }
        ul {
            margin: 10px 0;
            padding-left: 25px;
        }
        li {
            margin-bottom: 6px;
        }
        .signature {
            margin-top: 40px;
        }
        .footer { 
            font-size: 12px; 
            color: #888; 
            margin-top: 40px; 
            border-top: 1px solid #eaeaea; 
            padding-top: 15px; 
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            Statement of Account
        </div>
        
        <div class="content">
            <p>Dear <strong><%= account.accountName %></strong>,</p>
            <p>Here is your statement for the period <strong><%= startDate %></strong> to <strong><%= endDate %></strong>.</p>

            <div class="section-title">Customer Invoices</div>
            <% if (soaData.customerInvoices.length) { %>
            <table>
                <thead>
                    <tr><th>Date</th><th>Invoice #</th><th>Amount</th></tr>
                </thead>
                <tbody>
                <% soaData.customerInvoices.forEach(inv => { %>
                    <tr>
                        <td><%= new Date(parseInt(inv.invoiceDate)).toLocaleDateString() %></td>
                        <td><%= inv.invoiceNumber %></td>
                        <td><%= inv.totalAmount %> <%= inv.currency || 'USD' %></td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
            <% } else { %>
            <p class="empty-state">No customer invoices during this period.</p>
            <% } %>

            <div class="section-title">Customer Payments</div>
            <% if (soaData.customerPayments.length) { %>
            <table>
                <thead>
                    <tr><th>Date</th><th>Payment #</th><th>Amount</th></tr>
                </thead>
                <tbody>
                <% soaData.customerPayments.forEach(pay => { %>
                    <tr>
                        <td><%= new Date(parseInt(pay.paymentDate)).toLocaleDateString() %></td>
                        <td><%= pay.paymentNumber %></td>
                        <td><%= pay.amount %> <%= pay.currency || 'USD' %></td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
            <% } else { %>
            <p class="empty-state">No customer payments during this period.</p>
            <% } %>

            <div class="section-title">Vendor Invoices</div>
            <% if (soaData.vendorInvoices.length) { %>
            <table>
                <thead>
                    <tr><th>Date</th><th>Invoice #</th><th>Amount</th></tr>
                </thead>
                <tbody>
                <% soaData.vendorInvoices.forEach(inv => { %>
                    <tr>
                        <td><%= new Date(parseInt(inv.invoiceDate)).toLocaleDateString() %></td>
                        <td><%= inv.invoiceNumber %></td>
                        <td><%= inv.totalAmount %> <%= inv.currency || 'USD' %></td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
            <% } else { %>
            <p class="empty-state">No vendor invoices during this period.</p>
            <% } %>

            <div class="section-title">Vendor Payments</div>
            <% if (soaData.vendorPayments.length) { %>
            <table>
                <thead>
                    <tr><th>Date</th><th>Payment #</th><th>Amount</th></tr>
                </thead>
                <tbody>
                <% soaData.vendorPayments.forEach(pay => { %>
                    <tr>
                        <td><%= new Date(parseInt(pay.paymentDate)).toLocaleDateString() %></td>
                        <td><%= pay.paymentNumber %></td>
                        <td><%= pay.amount %> <%= pay.currency || 'USD' %></td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
            <% } else { %>
            <p class="empty-state">No vendor payments during this period.</p>
            <% } %>

            <% if (soaData.disputes && soaData.disputes.length) { %>
            <div class="section-title">Open Disputes</div>
            <ul>
                <% soaData.disputes.forEach(d => { %>
                    <li><strong><%= d.invoiceNumber %></strong> - <%= d.status %> <% if (d.amount) { %>(<%= d.amount %>)<% } %></li>
                <% }); %>
            </ul>
            <% } %>

            <div class="signature">
                <p>Thank you for your continued business.</p>
                <p>Best regards,<br>
                <strong>Cyvoratech </strong></p>
                <% if (logoSrc) { %>
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin-top: 10px;">
                    <tr>
                        <td style="text-align: left;">
                            <img src="<%= logoSrc %>" alt="Cyvora" style="max-width: 120px; width: 120px; height: auto; display: block;" />
                        </td>
                    </tr>
                </table>
                <% } %>
            </div>
        </div>
        
        <div class="footer">
            <p>&copy; <%= new Date().getFullYear() %> CDR Billing System. All rights reserved.</p>
        </div>
    </div>
</body>
</html>