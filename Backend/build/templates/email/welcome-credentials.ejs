<!DOCTYPE html>
<html>
<head>
    <style>
        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif; 
            font-size: 14px; 
            line-height: 1.6; 
            color: #333; 
            margin: 0; 
            padding: 20px; 
            background-color: #ffffff;
        }
        .container { 
            max-width: 600px; 
            margin: 0 auto; 
        }
        .header { 
            font-size: 16px; 
            font-weight: bold; 
            padding-bottom: 15px; 
            border-bottom: 1px solid #eaeaea; 
            margin-bottom: 20px; 
        }
        .details { 
            margin: 25px 0; 
        }
        .details p { 
            margin: 6px 0; 
        }
        .section-title {
            font-size: 14px;
            font-weight: bold;
            margin-top: 30px;
            margin-bottom: 10px;
        }
        ul {
            margin: 10px 0;
            padding-left: 25px;
        }
        li {
            margin-bottom: 6px;
        }
        .button {
            display: inline-block;
            padding: 10px 20px;
            background-color: #333;
            color: #ffffff !important;
            text-decoration: none;
            border-radius: 4px;
            margin: 15px 0;
            font-weight: bold;
            font-size: 13px;
        }
        .signature {
            margin-top: 30px;
        }
        .footer { 
            font-size: 12px; 
            color: #888; 
            margin-top: 40px; 
            border-top: 1px solid #eaeaea; 
            padding-top: 15px; 
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            Welcome to CDR Billing System
        </div>
        
        <div class="content">
            <p>Dear <strong><%= firstName %> <%= lastName %></strong>,</p>
            
            <p>Your account has been successfully created. You can now access the platform using the credentials provided below.</p>

            <div class="details">
                <p><strong>Email Address:</strong> <%= email %></p>
                <p><strong>Temporary Password:</strong> <%= password %></p>
                <p><strong>Role:</strong> <%= role.replace(/-/g, ' ').toUpperCase() %></p>
                <% if (phone) { %><p><strong>Phone:</strong> <%= phone %></p><% } %>
            </div>

            <div>
                <a href="<%= portalUrl %>" class="button">Login to Portal</a>
            </div>

            <div class="section-title">Next Steps & Security</div>
            <ul>
                <li>Use the credentials above to log in to the portal.</li>
                <li><strong>Important:</strong> Please change your password immediately after your first login. Keep your credentials confidential.</li>
                <li>Explore your dashboard and available features based on your role.</li>
            </ul>

            <div class="signature">
                <p>If you have any questions or need assistance, please contact our support team.</p>
                <p>Best regards,<br>
                <strong>Cyvoratech </strong></p>
                <% if (logoSrc) { %>
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin-top: 10px;">
                    <tr>
                        <td style="text-align: left;">
                            <img src="<%= logoSrc %>" alt="Cyvora" style="max-width: 120px; width: 120px; height: auto; display: block;" />
                        </td>
                    </tr>
                </table>
                <% } %>
            </div>
        </div>

        <div class="footer">
            <p>&copy; <%= new Date().getFullYear() %> CDR Billing System. All rights reserved.</p>
            <p>This is an automated message. Please do not reply to this email.</p>
        </div>
    </div>
</body>
</html>