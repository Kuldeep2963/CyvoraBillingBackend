<!DOCTYPE html>
<html>
<head>
    <style>
        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif; 
            font-size: 14px; 
            line-height: 1.6; 
            color: #333; 
            margin: 0; 
            padding: 20px; 
            background-color: #ffffff;
        }
        .container { 
            max-width: 600px; 
            margin: 0 auto; 
        }
        .header { 
            font-size: 16px; 
            font-weight: bold; 
            padding-bottom: 15px; 
            border-bottom: 1px solid #eaeaea; 
            margin-bottom: 20px; 
        }
        .details { 
            margin: 25px 0; 
        }
        .details p { 
            margin: 6px 0; 
        }
        .signature {
            margin-top: 30px;
        }
        .footer { 
            font-size: 12px; 
            color: #888; 
            margin-top: 40px; 
            border-top: 1px solid #eaeaea; 
            padding-top: 15px; 
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            Dispute Raised
        </div>
        
        <div class="content">
            <p>Hi <strong><%= customer.accountName %></strong>,</p>
            
            <p>A new dispute has been raised against your account for invoice <strong><%= disputeData.invoiceNumber %></strong>.</p>
            
            <div class="details">
                <p><strong>Customer:</strong> <%= customer.accountName %></p>
                <p><strong>Invoice Number:</strong> <%= disputeData.invoiceNumber %></p>
                <p><strong>Dispute Amount:</strong> <%= customer.currency %> <%= disputeData.disputeAmount %></p>
                <p><strong>Mismatched Invoices Count:</strong> <%= disputeData.mismatchedCount %></p>
                <p><strong>Reason/Comment:</strong> <%= disputeData.comment %></p>
                <p><strong>Date Raised:</strong> <%= new Date().toLocaleString() %></p>
            </div>
            
            <div class="signature">
                <p>Best regards,<br>
                <strong>Cyvoratech </strong></p>
                <% if (logoSrc) { %>
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin-top: 10px;">
                    <tr>
                        <td style="text-align: left;">
                            <img src="<%= logoSrc %>" alt="Cyvora" style="max-width: 120px; width: 120px; height: auto; display: block;" />
                        </td>
                    </tr>
                </table>
                <% } %>
            </div>
        </div>
        
        <div class="footer">
            <p>&copy; <%= new Date().getFullYear() %> CDR Billing System. All rights reserved.</p>
        </div>
    </div>
</body>
</html>