<!DOCTYPE html>
<html>
<head>
    <style>
        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif; 
            font-size: 14px; 
            line-height: 1.6; 
            color: #333; 
            margin: 0; 
            padding: 20px; 
            background-color: #ffffff;
        }
        .container { 
            max-width: 600px; 
            margin: 0 auto; 
        }
        .header { 
            font-size: 16px; 
            font-weight: bold; 
            padding-bottom: 15px; 
            border-bottom: 1px solid #eaeaea; 
            margin-bottom: 20px; 
        }
        .details { 
            margin: 25px 0; 
        }
        .details p { 
            margin: 6px 0; 
        }
        .section-title {
            font-size: 14px;
            font-weight: bold;
            margin-top: 30px;
            margin-bottom: 10px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
        }
        th {
            text-align: left;
            padding: 10px 8px;
            border-bottom: 2px solid #eaeaea;
            color: #555;
            font-weight: bold;
        }
        td {
            padding: 10px 8px;
            border-bottom: 1px solid #eaeaea;
        }
        .signature {
            margin-top: 30px;
        }
        .footer { 
            font-size: 12px; 
            color: #888; 
            margin-top: 40px; 
            border-top: 1px solid #eaeaea; 
            padding-top: 15px; 
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            Payment Received
        </div>
        
        <div class="content">
            <p>Dear <strong><%= customer.accountName %></strong>,</p>
            
            <p>Thank you for your payment. We have received it successfully.</p>
            
            <div class="details">
                <p><strong>Payment Number:</strong> <%= payment.paymentNumber %></p>
                <p><strong>Amount Paid:</strong> <%= payment.amount %> <%= payment.currency || 'USD' %></p>
                <p><strong>Date:</strong> <%= new Date(parseInt(payment.paymentDate)).toLocaleDateString() %></p>
                <p><strong>Payment Method:</strong> <%= payment.paymentMethod %></p>
            </div>

            <div class="section-title">Payment Allocations</div>
            <table>
                <thead>
                    <tr>
                        <th>Invoice Number</th>
                        <th>Allocated Amount</th>
                        <th>Remaining Balance</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (payment.allocations && payment.allocations.length > 0) { %>
                        <% payment.allocations.forEach(function(allocation) { %>
                            <tr>
                                <td><%= allocation.invoice.invoiceNumber %></td>
                                <td><%= allocation.allocatedAmount %> <%= allocation.invoice.currency || 'USD' %></td>
                                <td><%= allocation.invoice.balanceAmount %> <%= allocation.invoice.currency || 'USD' %></td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td><%= invoice.invoiceNumber %></td>
                            <td><%= payment.amount %> <%= invoice.currency || 'USD' %></td>
                            <td><%= invoice.balanceAmount %> <%= invoice.currency || 'USD' %></td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
            
            <div class="signature">
                <p>If you have any questions, please contact our support team.</p>
                <p>Best regards,<br>
                <strong>Cyvoratech </strong></p>
                <% if (logoSrc) { %>
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin-top: 10px;">
                    <tr>
                        <td style="text-align: left;">
                            <img src="<%= logoSrc %>" alt="Cyvora" style="max-width: 120px; width: 120px; height: auto; display: block;" />
                        </td>
                    </tr>
                </table>
                <% } %>
            </div>
        </div>
        
        <div class="footer">
            <p>&copy; <%= new Date().getFullYear() %> CDR Billing System. All rights reserved.</p>
        </div>
    </div>
</body>
</html>